{
  "task": {
    "implementation": "jspsych_pm",
    "runner": "jspsych",
    "title": "NBack PM Images (Single PM Category)"
  },
  "mapping": {
    "targetKey": "m",
    "nonTargetKey": "z",
    "pmKey": "space"
  },
  "stimuliCsv": {
    "basePath": "/assets/nback-pm-modern",
    "idColumn": "file",
    "categories": {
      "food": "food.csv",
      "clothing": "clothing.csv",
      "other": "other.csv"
    }
  },
  "variables": {
    "id": {
      "scope": "trial",
      "value": "$local.itemId"
    },
    "variant": {
      "scope": "block",
      "value": "$local.stimulusVariant"
    },
    "between": {
      "scope": "participant",
      "sampler": {
        "type": "list",
        "values": [
          { "pm": "food", "control": "clothing" },
          { "pm": "clothing", "control": "food" }
        ]
      }
    },
    "mainBlockType": {
      "scope": "block",
      "sampler": {
        "type": "list",
        "values": ["pm", "control"],
        "without_replacement": true
      }
    },
    "mainNLevel": {
      "scope": "block",
      "sampler": {
        "type": "list",
        "values": [1, 3],
        "without_replacement": true
      }
  },
  "imageAssets": {
    "enabled": true,
    "basePath": "/assets/nback-pm-modern/images",
    "filenameTemplate": "{id}{variant}-photo-colour.png",
    "practiceVariant": 3,
    "mainVariants": [1, 2],
    "mainMode": "with_replacement"
  },
  "nbackRule": {
    "lureLagPasses": [[2, 4, 5], [6, 7, 8, 9]],
    "maxInsertionAttempts": 10
  },
  "plan": {
    "manipulations": [
      { "id": "pm_block", "overrides": { "blockType": "pm" } },
      { "id": "control_block", "overrides": { "blockType": "control" } },
      { "id": "nlevel_1", "overrides": { "nLevel": 1 } },
      { "id": "nlevel_2", "overrides": { "nLevel": 2 } },
      { "id": "nlevel_3", "overrides": { "nLevel": 3 } },
      { "id": "main",
        "overrides": {
          "blockType": "$var.mainBlockType",
          "nLevel": "$var.mainNLevel"
        }
      }
    ],
    "blocks": [
      { "phase": "practice", "label": "Practice 2-back", "manipulations": ["control_block", "nlevel_2"], "trials": 20 },
      { "phase": "practice", "label": "Practice 1-back PM", "manipulations": ["pm_block", "nlevel_1"], "trials": 20 },
      { "phase": "practice", "label": "Practice 3-back", "manipulations": ["control_block", "nlevel_3"], "trials": 20 },
      { "phase": "main", "label": "Main 1", "manipulation": "main", "trials": 54 },
      { "phase": "main", "label": "Main 2", "manipulation": "main", "trials": 54 },
      { "phase": "main", "label": "Main 3", "manipulation": "main", "trials": 54 },
      { "phase": "main", "label": "Main 4", "manipulation": "main", "trials": 54 }
    ]
  }
}
