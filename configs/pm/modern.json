{
  "task": {
    "implementation": "jspsych_pm",
    "runner": "jspsych",
    "title": "NBack PM Modern",
    "rtTask": {
      "enabled": true,
      "timing": {
        "trialDurationMs": 5000,
        "fixationOnsetMs": 0,
        "fixationDurationMs": 500,
        "stimulusOnsetMs": 1000,
        "stimulusDurationMs": 4000,
        "responseWindowStartMs": 1000,
        "responseWindowEndMs": 5000
      },
      "responseTerminatesTrial": false
    }
  },
  "mapping": {
    "targetKey": "m",
    "nonTargetKey": "z",
    "pmKey": "space"
  },
  "nbackRule": {
    "lureLagPasses": [[2, 4, 5], [6, 7, 8, 9]],
    "maxInsertionAttempts": 10
  },
  "variables": {
    "mainBlockType": {
      "scope": "block",
      "sampler": {
        "type": "list",
        "values": ["pm", "control"],
        "without_replacement": true
      }
    },
    "mainNLevel": {
      "scope": "block",
      "sampler": {
        "type": "list",
        "values": [1, 3],
        "without_replacement": true
      }
    }
  },
  "plan": {
    "manipulations": [
      { "id": "pm_block", "overrides": { "blockType": "pm" } },
      { "id": "control_block", "overrides": { "blockType": "control" } },
      { "id": "nlevel_1", "overrides": { "nLevel": 1 } },
      { "id": "nlevel_2", "overrides": { "nLevel": 2 } },
      { "id": "nlevel_3", "overrides": { "nLevel": 3 } },
      {
        "id": "main_sampled",
        "overrides": {
          "blockType": "$var.mainBlockType",
          "nLevel": "$var.mainNLevel"
        }
      }
    ],
    "blocks": [
      { "phase": "practice", "label": "Practice 2-back", "manipulations": ["control_block", "nlevel_2"], "trials": 20 },
      { "phase": "practice", "label": "Practice 1-back PM", "manipulations": ["pm_block", "nlevel_1"], "trials": 20 },
      { "phase": "practice", "label": "Practice 3-back", "manipulations": ["control_block", "nlevel_3"], "trials": 20 },
      { "phase": "main", "label": "Main 1", "manipulation": "main_sampled", "trials": 54 },
      { "phase": "main", "label": "Main 2", "manipulation": "main_sampled", "trials": 54 },
      { "phase": "main", "label": "Main 3", "manipulation": "main_sampled", "trials": 54 },
      { "phase": "main", "label": "Main 4", "manipulation": "main_sampled", "trials": 54 }
    ]
  }
}
