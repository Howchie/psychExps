{
  "task": {
    "title": "Random Dot Kinetogram"
  },
  "instructions": {
    "intro": [
      "You will see a field of dots.",
      "If the dots are moving, determine their predominant direction (Left, Right, Up, Down).",
      "If the dots are static and colored, determine the predominant color (Black or White)."
    ]
  },
  "display": {
    "aperturePx": 500,
    "frameBackground": "#1e293b",
    "frameBorder": "#334155",
    "canvasBackground": "#94a3b8",
    "showCrosshair": true
  },
  "trialDefaults": {
    "mode": "dynamic",
    "durationMs": 5000,
    "coherenceStart": 0.5,
    "coherenceEnd": 0.5,
    "coherenceDurationMs": 0,
