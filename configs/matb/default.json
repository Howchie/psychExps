      { "timeMs": 420000, "target": "comms",   "command": "prompt", "value": { "callsign": "ECHO775",  "radio": "nav2", "frequency": 116.2 } },
      { "timeMs": 440000, "target": "sysmon",  "command": "set", "path": "light2.failure", "value": true },
