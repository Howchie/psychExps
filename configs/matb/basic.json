{
  "task": {
    "title": "MATB Basic",
    "durationMs": 60000
  },
  "instructions": {
    "intro": [
      "This is a 1-minute MATB demonstration session.",
      "Monitor all four tasks and respond as accurately as possible.",
      "Press Continue when ready."
    ],
    "end": [
      "Session complete. Thank you."
    ]
  },
  "layout": {
    "rows": 2,
    "cols": 2,
    "gap": "2px",
    "background": "#111",
    "panels": [
      { "id": "sysmon",   "row": 0, "col": 0, "label": "SYSMON" },
      { "id": "tracking", "row": 0, "col": 1, "label": "TRACKING" },
      { "id": "comms",    "row": 1, "col": 0, "label": "COMMS" },
      { "id": "resman",   "row": 1, "col": 1, "label": "RESMAN" }
    ]
  },
  "subtasks": {
    "sysmon": {
      "alertTimeoutMs": 10000,
      "feedbackDurationMs": 1500,
      "driftIntervalMs": 200
    },
    "tracking": {
      "perturbation": {
        "components": [
          { "axis": "x", "frequencyHz": 0.03, "amplitude": 100 },
          { "axis": "y", "frequencyHz": 0.05, "amplitude": 100 }
        ],
        "gainRatio": 0.8
      }
    },
    "comms": {
      "responseTimeoutMs": 20000,
      "speech": {
        "voiceNames": [
          "Google UK English Male",
          "Microsoft David - English (United States)",
          "Microsoft Mark - English (United States)",
          "Alex",
          "Daniel"
        ],
        "lang": "en-US",
        "rate": 0.9,
        "pitch": 1.0
      }
    },
    "resman": {}
  },
  "scenario": {
    "events": [
      { "timeMs":  2000, "target": "comms",  "command": "prompt", "value": { "callsign": "NASA504",  "radio": "com1", "frequency": 118.3 } },
      { "timeMs": 10000, "target": "sysmon", "command": "set", "path": "scale1.failure", "value": "down" },
      { "timeMs": 15000, "target": "resman", "command": "set", "path": "pump.3.state", "value": "failed" },
      { "timeMs": 25000, "target": "resman", "command": "set", "path": "pump.3.state", "value": "off" },
      { "timeMs": 25000, "target": "comms",  "command": "prompt", "value": { "callsign": "DELTA221", "radio": "nav1", "frequency": 110.6 } },
      { "timeMs": 30000, "target": "sysmon", "command": "set", "path": "scale4.failure", "value": "up" },
      { "timeMs": 30000, "target": "resman", "command": "set", "path": "pump.7.state", "value": "failed" },
      { "timeMs": 40000, "target": "resman", "command": "set", "path": "pump.7.state", "value": "off" },
      { "timeMs": 45000, "target": "comms",  "command": "prompt", "value": { "callsign": "NASA504",  "radio": "com2", "frequency": 124.8 } }
    ]
  }
}
