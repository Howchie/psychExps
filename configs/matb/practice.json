{
  "task": {
    "title": "MATB Practice",
    "durationMs": 180000
  },
  "instructions": {
    "intro": [
      "This is a 3-minute practice session to familiarise you with all four tasks.",
      "SYSMON (top-left): Watch for indicator failures. Press F1–F4 for scale gauges; F5–F6 for lights.",
      "TRACKING (top-right): Keep the red cursor inside the reticle. Click the canvas to lock the mouse.",
      "COMMS (bottom-left): Listen for your callsign (NASA504). Use ↑↓ to select a radio, ←→ to tune, Enter to confirm.",
      "RESMAN (bottom-right): Keep tanks A and B near 2500 units using numpad keys 1–8.",
      "Events occur slowly during practice. Press Continue when ready."
    ],
    "end": [
      "Practice complete. In the main session, events will occur more frequently.",
      "Press Continue when you are ready to begin the main session."
    ]
  },
  "layout": {
    "rows": 2,
    "cols": 3,
    "gap": "2px",
    "background": "#d0d0d0",
    "panels": [
      { "id": "sysmon",     "row": 0, "col": 0, "label": "SYSTEM MONITORING" },
      { "id": "tracking",   "row": 0, "col": 1, "label": "TRACKING" },
