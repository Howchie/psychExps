{
  "task": {
    "title": "MATB Parasuraman Low Reliability",
    "durationMs": 600000
  },
  "instructions": {
    "intro": [
      "You are about to begin a 10-minute monitoring session.",
      "SYSMON (top-left): Watch for indicator failures. Press F1–F4 for scale gauges; F5–F6 for lights.",
      "TRACKING (top-right): Keep the red cursor inside the reticle.",
      "RESMAN (bottom-right): Keep tanks A and B near their target levels.",
      "In this session, only some failures will be resolved automatically.",
      "Still respond as quickly and accurately as you can.",
      "Press Continue when ready."
    ],
    "end": [
      "Session complete. Thank you."
    ]
  },
  "layout": {
    "rows": 2,
    "cols": 2,
    "gap": "2px",
    "background": "#111",
    "panels": [
      { "id": "sysmon",   "row": 0, "col": 0, "label": "SYSMON" },
      { "id": "tracking", "row": 0, "col": 1, "label": "TRACKING" },
      { "id": "resman",   "row": 1, "col": 1, "label": "RESMAN" }
    ]
  },
  "subtasks": {
    "sysmon": {
      "alertTimeoutMs": 10000,
      "feedbackDurationMs": 1500,
      "driftIntervalMs": 200,
      "scales": [
        { "id": "scale1", "label": "TEMP1", "key": "f1", "driftSpeed": 1 },
        { "id": "scale2", "label": "PRES1", "key": "f2", "driftSpeed": 1 },
        { "id": "scale3", "label": "TEMP2", "key": "f3", "driftSpeed": 1 },
        { "id": "scale4", "label": "PRES2", "key": "f4", "driftSpeed": 1 }
      ],
      "lights": [
        { "id": "light1", "label": "OK",      "onColor": "#22c55e", "offColor": "#555", "defaultOn": true,  "key": "f5" },
        { "id": "light2", "label": "WARNING", "onColor": "#ef4444", "offColor": "#555", "defaultOn": false, "key": "f6" }
      ]
    },
    "tracking": {
      "perturbation": {
        "components": [
          { "axis": "x", "frequencyHz": 0.06, "amplitude": 140 },
          { "axis": "y", "frequencyHz": 0.06, "amplitude": 140 }
        ],
        "gainRatio": 0.8
      }
    },
    "comms": {},
    "resman": {}
  },
  "scenario": {
