{
  "_comment": "Parasuraman et al. (1993) two-block reliability manipulation with concurrent border DRT.",
  "_comment2": "Block 1 = high reliability (most failures auto-resolve). Block 2 = low reliability (fewer auto-resolutions). A NASA-TLX survey runs once at the end. DRT uses a red border around the MATB display area; respond with Space.",
  "ui": {
    "pageBackground": "0a0a0a",
    "cardWidth": "800px",
    "cardMinHeight": "600px",
    "cardBackground": "0a0a0a",
    "cardBorder": "1px solid rgba(255, 255, 255, 0.95)",
    "cardBorderRadius": "12px",
    "cardColor": "rgba(255, 255, 255, 0.95)",
    "cardFontSize": "1.2rem",
    "cardFontFamily": "system-ui, -apple-system, sans-serif"
  },
  "task": {
    "title": "MATB — Reliability & Workload",
    "modules": {
      "drt": {
        "enabled": true,
        "scope": "block",
        "key": "space",
        "responseWindowMs": 2500,
        "displayDurationMs": 1000,
        "responseTerminatesStimulus": true,
        "stimMode": "border",
        "border": {
          "color": "#dc2626",
          "widthPx": 5,
          "radiusPx": 3,
          "target": "display"
        },
        "isiSampler": {
          "type": "uniform",
          "min": 3000,
          "max": 5000
        }
      }
    }
  },

  "display": {
    "maxWidthPx": 800,
    "maxHeightPx": 600,
    "minWidthPx": 800,
    "minHeightPx": 600,
    "aspectRatio": "4/3",
    "marginPx": 48,
    "background": "#0a0a0a"
  },

  "instructions": {
    "intro": [
      "Welcome to the Multi-Attribute Task Battery (MATB).",
      "You will perform four tasks simultaneously across two 10-minute blocks separated by a short break.",
      "SYSMON (top-left): Monitor four scale gauges and two lights. When a gauge drifts out of range or a light shows a failure state, press the assigned key (F1–F4 for scales, F5–F6 for lights) to acknowledge it.",
      "TRACKING (top-right): Keep the red cursor inside the circular reticle by moving the mouse. Try to minimise the time spent outside the boundary.",
      "COMMS (bottom-left): Audio messages will announce a callsign, a radio, and a target frequency. This panel is automated — you do not need to respond to it.",
      "RESMAN (bottom-right): Maintain fuel levels in tanks A and B near their target values by switching pumps on and off with the number keys. Some pumps may fail during the task.",
      "SECONDARY TASK — Detection Response Task (DRT): Occasionally a red border will flash around the display. Press the Space bar as quickly as possible whenever you see it. Do this while continuing all primary tasks.",
      "Your task is to manage all four tasks as well as possible at the same time. The DRT probe will appear throughout both blocks.",
      "Press Continue when you are ready to begin."
    ],
    "end": [
      "The session is now complete.",
      "Thank you for your participation.",
      "Please complete the workload questionnaire on the next screen."
    ]
  },

  "layout": {
    "rows": 2,
    "cols": 2,
    "gap": "3px",
    "background": "#1a1a1a",
    "panels": [
      { "id": "sysmon",   "row": 0, "col": 0, "label": "SYSMON" },
      { "id": "tracking", "row": 0, "col": 1, "label": "TRACKING" },
      { "id": "comms",    "row": 1, "col": 0, "label": "COMMS" },
      { "id": "resman",   "row": 1, "col": 1, "label": "RESMAN" }
    ]
  },

  "subtasks": {
    "sysmon": {
      "alertTimeoutMs": 10000,
      "feedbackDurationMs": 1500,
      "driftIntervalMs": 200,
      "scales": [
        { "id": "scale1", "label": "TEMP1", "key": "f1", "driftSpeed": 1 },
        { "id": "scale2", "label": "PRES1", "key": "f2", "driftSpeed": 1 },
        { "id": "scale3", "label": "TEMP2", "key": "f3", "driftSpeed": 1 },
        { "id": "scale4", "label": "PRES2", "key": "f4", "driftSpeed": 1 }
      ],
      "lights": [
        { "id": "light1", "label": "OK",      "onColor": "#22c55e", "offColor": "#555", "defaultOn": true,  "key": "f5" },
        { "id": "light2", "label": "WARNING", "onColor": "#ef4444", "offColor": "#555", "defaultOn": false, "key": "f6" }
      ]
    },
    "tracking": {
      "perturbation": {
        "components": [
          { "axis": "x", "frequencyHz": 0.06, "amplitude": 140 },
          { "axis": "y", "frequencyHz": 0.06, "amplitude": 140 }
        ],
        "gainRatio": 0.8
      }
    },
    "comms": { "automated": true, "muteAudio": true, "automatedResponseDelayMs": 3000 },
    "resman": {}
  },

