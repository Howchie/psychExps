{
  "task": {
    "implementation": "jspsych_stroop",
    "runner": "jspsych",
    "title": "Emotional Stroop",
    "instructions": "Ignore the word content and respond to font color.",
    "rtTask": {
      "timing": {
        "trialDurationMs": 2200,
        "fixationOnsetMs": 0,
        "fixationDurationMs": 600,
        "stimulusOnsetMs": 800,
        "stimulusDurationMs": 1400,
        "responseWindowStartMs": 800,
        "responseWindowEndMs": 1900
      },
      "responseTerminatesTrial": false,
      "postResponseContent": "stimulus",
      "feedbackPhase": "separate"
    }
  },
  "mapping": {
    "redKey": "f",
    "greenKey": "j"
  },
  "display": {
    "aperturePx": 440,
    "frameBackground": "#ffffff",
    "frameBorder": "2px solid #d1d5db",
    "fixationColor": "#111827",
    "stimulusFontSizePx": 56,
    "stimulusFontWeight": 700,
    "textColorByToken": {
      "red": "#ff0000",
      "green": "#00aa00"
    }
  },
  "stimuli": {
    "responseColorTokens": ["red", "green"],
    "wordsCsv": {
      "basePath": "{runtime.configsBase}/stroop",
      "path": "emotional_words.csv",
      "column": "neutral"
    },
    "valenceLists": {
      "csv": {
        "basePath": "{runtime.configsBase}/stroop",
        "path": "emotional_words.csv",
        "columns": {
          "positive": "positive",
          "neutral": "neutral",
          "negative": "negative"
        }
      }
    }
  },
  "conditions": {
    "mode": "valence",
    "quotaPerBlock": {
      "positive": 10,
      "neutral": 10,
      "negative": 10
    },
    "fontColorQuotaPerBlock": {
      "red": 15,
      "green": 15
    },
    "maxConditionRunLength": 3,
    "noImmediateWordRepeat": true
  },
  "plan": {
    "blockCount": 2,
    "blockTemplate": {
      "label": "Block {blockIndex}",
      "trials": 30
    }
  },
  "feedback": {
    "enabled": false,
    "durationMs": 350
  }
}
