{
  "ui": {
    "pageBackground": "linear-gradient(180deg, #DBDBDB 0%, #ADADAD 100%)",
    "cardWidth": "600px",
    "cardMinHeight": "400px",
    "cardBorder": "1px solid #111111",
    "cardBorderRadius": "12px",
    "cardFontSize": "1.2rem",
    "cardFontFamily": "system-ui, -apple-system, sans-serif"
  },
  "task": {
    "implementation": "native_bricks",
    "runner": "native",
    "title": "Bricks Task",
    "modules": {
      "drt": {
        "enabled": true,
        "scope": "trial",
        "key": " ",
        "audio": {
          "volume": 0
        },
        "stimMode": "border",
        "border": {
          "widthPx": 10,
          "radiusPx": 0,
          "target": "display"
        },
        "isiSampler": {
          "type": "uniform",
          "min": 3000,
          "max": 5000
        },
        "transformPersistence": "session",
        "responseDeadlineMs": 2500,
        "parameterTransforms": [
          {
            "type": "wald_conjugate",
            "t0Mode": "min_rt_multiplier",
            "t0Multiplier": 0.5,
            "priorUpdate": {
              "enabled": true,
              "mode": "shift_means"
            }
          }
        ]
      }
    }
  },
  "display": {
    "canvasWidth": 800,
    "canvasHeight": 600,
    "viewportPaddingPx": 24,
    "backgroundColor": "#7f858a",
    "beltColor": "#e5e7eb",
    "beltHeight": 56,
    "beltGap": 50,
    "brickHeight": 36,
    "brickCornerRadius": 3,
    "beltTexture": {
      "scrollSnapMode": "screen",
      "scrollRenderMode": "auto"
    },
    "spotlight": {
      "snapMode": "none",
      "cornerRadiusPx": 10,
      "ringWidthPx": 3,
      "ringAlpha": 0.95
    },
    "brickTextureOverlay": {
      "enable": true,
      "alpha": 1,
      "baseFillAlpha": 1,
      "plankCount": 3,
      "seamWidthPx": 1,
      "grainCount": 4,
      "nailRadiusPx": 1,
      "insetPx": 2,
      "styles": {
        "pizza_pepperoni": {
          "pattern": "pizza",
          "baseFillColor": "#e8bf8f",
          "baseFillAlpha": 1,
          "alpha": 1,
          "sliceCount": 8,
          "toppingCount": 8,
          "crustColor": "#a16207",
          "sauceColor": "#b91c1c",
          "cheeseColor": "#facc15",
          "toppingColor": "#7f1d1d",
          "sliceLineColor": "#7c2d12"
        },
        "pizza_margherita": {
          "pattern": "pizza",
          "baseFillColor": "#e8bf8f",
          "baseFillAlpha": 1,
          "alpha": 1,
          "sliceCount": 6,
          "toppingCount": 5,
          "crustColor": "#b45309",
          "sauceColor": "#991b1b",
          "cheeseColor": "#fcd34d",
          "toppingColor": "#166534",
          "sliceLineColor": "#7c2d12"
        },
        "pizza_hawaiian": {
          "pattern": "pizza",
          "baseFillColor": "#efc697",
          "baseFillAlpha": 1,
          "alpha": 1,
          "sliceCount": 8,
          "toppingCount": 10,
          "crustColor": "#92400e",
          "sauceColor": "#b91c1c",
          "cheeseColor": "#fde047",
          "toppingColor": "#f59e0b",
          "sliceLineColor": "#7c2d12"
        },
        "pizza_bbq": {
          "pattern": "pizza",
          "baseFillColor": "#e0b27a",
          "baseFillAlpha": 1,
          "alpha": 1,
          "sliceCount": 10,
          "toppingCount": 12,
          "crustColor": "#78350f",
          "sauceColor": "#7f1d1d",
          "cheeseColor": "#fbbf24",
          "toppingColor": "#7c2d12",
          "sliceLineColor": "#451a03"
        }
      }
    },
    "ui": {
      "showHUD": true,
      "hudFontFamily": "\"Segoe UI\", \"Helvetica Neue\", Arial, sans-serif",
      "hudFontSize": 16,
      "hudFontWeight": 600,
      "hudPanel": true,
      "hudPanelColor": "#0f172a",
      "hudPanelAlpha": 0.38,
      "showTimer": false,
      "showRemainingBlocks": false,
      "showDroppedBlocks": true,
      "showPoints": true,
      "showDRT": false
    },
    "dueDateMarker": {
      "enable": true,
      "color": "#111827",
      "widthPx": 4,
      "heightPx": 44,
      "alpha": 0.95
    },
    "missAnimation": {
      "mode": "disintegrate",
      "durationMs": 240,
      "markerFlashMs": 150,
      "flashColor": "#ef4444",
      "disintegrate": {
        "shardCount": 30,
        "durationMs": 230,
        "gravityPxPerSec2": 620,
        "speedMinPxPerSec": 120,
        "speedMaxPxPerSec": 250,
        "furnaceBias": 0.15
      }
    },
    "clearAnimation": {
      "enable": true,
      "timeoutMs": 1000,
      "risePx": 28,
      "startOffsetYPx": 10,
      "textColor": "#ffe082",
      "textStrokeColor": "#4a2f05",
      "textStrokeThickness": 4,
      "textMinSizePx": 16,
      "textMaxSizePx": 40,
      "textSizeFactor": 0.62,
      "coin": {
        "enable": true,
        "showInPointsAnimation": true,
        "showInHud": true,
        "sizePx": 20,
        "gapPx": 6,
        "ridgeCount": 18
      }
    },
    "endFurnace": {
      "enable": true,
      "offsetX": 2
    },
    "preset": {
      "mode": "fixed",
      "id": "warehouse_concrete_checker"
    },
    "performance": {
      "maxDevicePixelRatio": 1.5,
      "antialias": true,
      "imageRendering": "auto",
      "pixelSnapBricks": false
    }
  },
  "conveyors": {
    "nConveyors": 4,
    "lengthPx": {
      "type": "uniform",
      "min": 560,
      "max": 740
    },
    "speedPxPerSec": {
      "type": "fixed",
      "value": 20
    }
  },
  "bricks": {
    "completionMode": "hold_to_clear",
    "interaction": {
      "targetingArea": "conveyor"
    },
    "completionParams": {
      "hold_process_rate_px_s": 12
    },
    "shapeCategories": [
      {
        "id": "PizzaShape",
        "shape": "circle"
      }
    ],
    "textureCategories": [
      {
        "id": "Pizza",
        "label": "Pizza",
        "textureStyle": {
          "type": "list",
          "values": [
            "pizza_pepperoni",
            "pizza_margherita",
            "pizza_hawaiian",
            "pizza_bbq"
          ],
          "without_replacement": true
        },
        "value": {
          "type": "fixed",
          "value": 5
        }
      }
    ],
    "initialBricks": {
      "type": "fixed",
      "value": 0
    },
    "forcedSet": [],
    "forcedSetPlan": {
      "enable": true,
      "count": 4,
      "defaults": {
        "width": {
          "type": "fixed",
          "value": 36
        }
      },
      "fields": {
        "conveyorIndex": {
          "values": [
            0,
            1,
            2,
            3
          ],
          "draw": "without_replacement"
        },
        "shapeCategoryId": {
          "values": [
            "PizzaShape",
            "PizzaShape",
            "PizzaShape",
            "PizzaShape"
          ]
        },
        "rightEdge": 150,
        "textureCategoryId": {
          "values": [
            "Pizza",
            "Pizza",
            "Pizza",
            "Pizza"
          ]
        }
      }
    },
    "maxBricksPerTrial": 4,
    "spawn": {
      "ratePerSec": {
        "type": "fixed",
        "value": 0
      },
      "interSpawnDist": null,
      "minSpacingPx": 0,
      "byConveyor": true,
      "maxActivePerConveyor": 1
    }
  },
  "difficultyModel": {
    "holdQualityMean": 0.8
  },
  "trial": {
    "mode": "max_bricks",
    "maxTimeSec": null,
    "brickQuotaEndDelayMs": 1000,
    "stopDrtOnBrickQuotaMet": true
  },
  "experiment": {
    "showBetweenBlockSummary": true,
    "startTrialsOn": "click",
    "startOverlay": {
      "text": "Click to begin.",
      "padding": "0",
      "background": "transparent",
      "border": "none",
      "borderRadius": "0",
      "boxShadow": "none",
      "buttonStyle": {
        "background": "black",
        "border": "none",
        "borderRadius": "200px",
        "padding": "18px 32px",
        "fontSize": "24px",
        "outline": "none",
        "boxShadow": "none"
      }
    },
    "statsPresentation": {
      "scopeByMetric": {
        "points": "experiment",
        "cleared": "block",
        "dropped": "block"
      },
      "reset": [
        {
          "at": "block_end",
          "scope": "experiment",
          "metrics": [
            "points"
          ],
          "when": {
            "isPractice": true
          }
        }
      ]
    }
  },
  "surveys": {
    "postTrial": [
      {
        "preset": "atwit",
        "showQuestionNumbers": false,
        "showRequiredAsterisk": false,
        "questionBorder": "none",
        "questionBorderRadius": "0",
        "prompt": "Rate your overall workload during the just-completed trial (1-10).",
        "title": ""
      }
    ]
  },
  "manipulations": [
    {
      "id": "difficulty_practice",
      "label": "Practice speed",
      "overrides": {
        "conveyors": {
          "speedPxPerSec": {
            "type": "fixed",
            "value": 12
          }
        }
      }
    },
    {
      "id": "difficulty_low",
      "label": "Low speed",
      "overrides": {
        "conveyors": {
          "speedPxPerSec": {
            "type": "fixed",
            "value": 26
          }
        }
      }
    },
    {
      "id": "difficulty_high",
      "label": "High speed",
      "overrides": {
        "conveyors": {
          "speedPxPerSec": {
            "type": "fixed",
            "value": 32
          }
        }
      }
    }
  ],
  "blocks": [
    {
      "label": "Practice1",
      "phase": "practice",
      "trials": 3,
      "overrides": {
        "task": {
          "modules": {
            "drt": {
              "enabled": false
            }
          }
        }
      },
      "repeatUntil": {
          "enabled": true,
          "maxAttempts": 3,
          "minMeanMetric": 3,
          "metrics": {
            "correctField": "game.stats.cleared",
            "metricField": "game.stats.cleared"
          }
      },
      "repeatAfterBlockScreens": [
        "Let's have another try.\nRemember: click and hold on the conveyor belt where a pizza is moving.\nKeep holding until the pizza clears, then release.\nDo this for each pizza in turn."
      ],
      "manipulations": [
        "difficulty_practice"
      ],
      "preBlockScreens": [
        "We will now try to clear some pizzas!\n\nIn the following trials, pizzas will move slowly along the conveyor belts.\nYou must click and hold your mouse button on the conveyor belt to clear each pizza.\n\nTry to clear as many pizzas as possible to collect more coins!\n\nAfter each trial you will be asked to rate your experienced workload on a scale of 1-10."
      ],
      "afterBlockScreens": [
        {
          "html": "<div style='font-family: system-ui, -apple-system, sans-serif; font-size: 1.2rem; line-height: 1.45;'>Well done!<p>As part of this experiment, you will also be asked to respond to a flashing stimulus called the DRT.<p>Whenever you see the border of the experiment window flash red, like this<p><img src='assets/drt_border.png' alt='DRT example' style='max-width: 480px; width: 100%; height: auto;'/><p>You should press the SPACEBAR as quickly as possible. This will happen repeatedly throughout the conveyor task.<p></div>"
        }
      ]
    },
    {
      "label": "DRTPractice",
      "phase": "practice",
      "trials": 1,
      "overrides": {
        "display": {
          "ui": {
            "showHUD": false
          }
        },
        "trial": {
          "mode": "fixed_time",
          "maxTimeSec": 60,
          "endDelayMs": 0
        },
        "bricks": {
          "initialBricks": {
            "type": "fixed",
            "value": 0
          },
          "forcedSet": [],
          "forcedSetPlan": {
            "enable": false,
            "count": 0
          },
          "maxBricksPerTrial": 0,
          "spawn": {
            "ratePerSec": {
              "type": "fixed",
              "value": 0
            },
            "initialBricks": 0,
            "interSpawnDist": null
          }
        },
        "surveys": {
          "postTrial": []
        }
      },
      "preBlockScreens": [
        "Let's practice the DRT.\nIgnore the conveyors and focus only on the red border signal.\n\nPress SPACEBAR as quickly as possible whenever the border flashes red.\n\nThis block will end after 60 seconds."
      ],
      "afterBlockScreens": ["Great job!\n\nWe will now do some practice trials putting both tasks together.\n\nRemember, use your mouse to clear pizzas by click-and-holding on the conveyor belt.\nPress SPACEBAR whenever you see the red square.\n\nThe conveyors will start to move a little more quickly now."]
    },
    {
      "label": "Practice2",
      "phase": "practice",
      "trials": 3,
      "manipulations": [
        "difficulty_low"
      ],
      "afterBlockScreens": [
        "Great job! From here on you will always complete both the detection task and the conveyor task.\n\nThe conveyor will change speeds between blocks and sometimes it will be difficult to clear all the pizzas."
      ]
    },
    {
      "label": "Block1",
      "phase": "main",
      "trials": 4,
      "manipulations": [
        "difficulty_low"
      ],
      "afterBlockScreens": [
        "The conveyors will move a little faster now."
      ]
    },
    {
      "label": "High Difficulty",
      "phase": "main",
      "trials": 4,
      "manipulations": [
        "difficulty_high"
      ]
    }
  ],
  "instructions": {
    "introPages": [
      {
        "html": "<div style='font-family: system-ui, -apple-system, sans-serif; font-size: 1.2rem; line-height: 1.45;'>Welcome to the pizza task!<p>You will play a game where you will try to clear as many pizzas as you can within a time limit. Each trial will display four conveyor belts with moving pizzas. Clearing a pizza will give you coins.<p>Each line ends at a furnace. If any pizza reaches the furnace, it is destroyed and you will not get that reward.</div>"
      },
      "To clear a pizza, click and hold the left mouse button anywhere on the conveyor belt while the pizza is under your cursor. Keep holding until the pizza disappears, then release and move to the next one."
    ],
    "blockSummary": {
      "enabled": true,
      "at": "block_end_before_post",
      "when": {
        "isPractice": false
      },
      "title": "End of {blockLabel}",
      "lines": [
        "Pizzas cleared: {blockCleared}",
        "Pizzas lost: {blockDropped}",
        "Current coin balance: {experimentPoints}"
      ],
      "metrics": {
        "correctField": "responseCorrect",
        "rtField": "responseRtMs"
      }
    },
    "showBlockIntro": false,
    "showBlockLabel": false,
    "endPages": "That concludes the experiment.\nThank you very much for participating."
  }
}
