        "trial": {
          "mode": "max_bricks",
          "holdDurationPractice": {
            "requiredPresses": 20,
            "fullWidthConveyor": true,
            "centerBrick": false,
            "hideHud": true,
            "replenishDelayMs": 250,
            "useSpotlightWindow": true
          }
