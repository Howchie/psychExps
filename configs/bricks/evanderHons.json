  "task": {
    "implementation": "native_bricks",
    "runner": "native",
    "title": "Bricks Task",
    "modules": {
      "drt": {
        "enabled": true,
        "scope": "trial",
        "key": " ",
        "audio": {
          "volume": 0.0
        },
        "stimMode": "border",
        "border": {
            "widthPx": 10,
            "radiusPx": 0,
            "target": "display"
        },
        "isiSampler": {
          "type": "uniform",
          "min": 3000,
          "max": 5000
        },
        "transformPersistence": "session",
        "responseDeadlineMs": 2500,
        "parameterTransforms": [
          {
            "type": "wald_conjugate",
            "t0Mode": "min_rt_multiplier",
            "t0Multiplier": 0.5,
            "priorUpdate": {
              "enabled": true,
              "mode": "shift_means"
            }
          }
        ]
      }
    }
  },
