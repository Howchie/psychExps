        },
        "trial": {
          "mode": "fixed_time",
          "maxTimeSec": 60,
          "endDelayMs": 0,
          "forcedOrder": {
            "enable": false
          }
        },
        "bricks": {
          "initialBricks": {
            "type": "fixed",
            "value": 0
          },
          "forcedSet": [],
          "forcedSetPlan": {
            "enable": false,
            "count": 0
