    "blocks": [
    {
      "label": "Practice1",
      "phase": "practice",
      "trials": 3,
      "overrides": {
              "task": {
                  "modules": {
                    "drt": { "enabled": false }
                  }
            }
       },
       "manipulations": [
        "difficulty_low",
        "condition_plan"
      ],
     "afterBlockScreens": [{"html": "Well done!<p>As part of this experiment, you will also be asked to respond to a flashing stimulus called the DRT.<p>Whenever you see the border of the experiment window flash red, like this<p><img src='assets/drt_border.png' alt='DRT example' style='max-width: 480px; width: 100%; height: auto;'/><p>You should press the SPACEBAR as quickly as possible. This will happen repeatedly throughout the conveyor task.<p>"},"We will now do some practice trials putting both tasks together. Remember, use your mouse cursor to open boxes by highlighting the conveyor, and press SPACEBAR whenever you see the red square."]
    },
    {
      "label": "Practice2",
      "phase": "practice",
      "trials": 3,
      "manipulations": [
        "difficulty_low",
        "condition_plan"
      ],
     "afterBlockScreens": ["Great job! From here on you will always complete both the detection task and the conveyor task.\n\nThe conveyor will change speeds between blocks and sometimes it will be difficult to open all the boxes."]
    },
    {
      "label": "Block1",
      "phase": "main",
      "trials": 4,
      "manipulations": [
        "difficulty_low",
        "condition_plan"
      ],
