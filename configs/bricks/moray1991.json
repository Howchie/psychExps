{
  "task": {
    "implementation": "native_bricks",
    "runner": "native",
    "title": "Bricks Moray 1991 VPT+VDD Test",
    "modules": {
      "drt": {
        "enabled": true,
        "scope": "trial",
        "key": " ",
        "audio": {
          "volume": 0.0
        },
        "stimMode": "border",
        "visual": {
          "shape": "square",
          "color": "#dc2626",
          "sizePx": 32,
          "leftPx": 600,
          "topPx": 30
        },
        "isiSampler": {
          "type": "uniform",
          "min": 3000,
          "max": 5000
        },
        "transformPersistence": "session",
        "responseDeadlineMs": 2500,
        "parameterTransforms": [
          {
            "type": "wald_conjugate",
            "t0Mode": "min_rt_multiplier",
            "t0Multiplier": 0.5,
            "priorUpdate": {
              "enabled": true,
              "mode": "shift_means"
            }
          }
        ]
      }
    }
  },
  "display": {
    "canvasWidth": 1200,
    "canvasHeight": 760,
    "viewportPaddingPx": 24,
    "backgroundColor": "#7f858a",
    "beltColor": "#e5e7eb",
    "beltHeight": 56,
    "beltGap": 50,
    "brickHeight": 36,
    "brickCornerRadius": 3,
    "beltTexture": {
        "scrollSnapMode": "screen",
        "scrollRenderMode": "auto"
    },
    "brickTextureOverlay": {
      "enable": true,
      "alpha": 0.5,
      "pattern": "wood_planks",
      "baseFillAlpha": 1,
      "baseFillColor": "#8b6f4e",
      "plankCount": 3,
      "seamWidthPx": 1,
      "grainCount": 4,
      "nailRadiusPx": 1,
      "insetPx": 2
    },
    "ui": {
      "showHUD": true,
      "hudFontFamily": "\"Segoe UI\", \"Helvetica Neue\", Arial, sans-serif",
      "hudFontSize": 16,
      "hudFontWeight": 600,
      "hudPanel": true,
      "hudPanelColor": "#0f172a",
      "hudPanelAlpha": 0.38,
      "showTimer": false,
      "showRemainingBlocks": false,
      "showDroppedBlocks": true,
      "showPoints": true,
      "showDRT": false
    },
    "dueDateMarker": {
      "enable": true,
      "color": "#111827",
      "widthPx": 4,
      "heightPx": 44,
      "alpha": 0.95
    },
    "missAnimation": {
      "mode": "disintegrate",
      "durationMs": 240,
      "markerFlashMs": 150,
      "flashColor": "#ef4444",
      "disintegrate": {
        "shardCount": 10,
        "durationMs": 230,
        "gravityPxPerSec2": 620,
        "speedMinPxPerSec": 120,
        "speedMaxPxPerSec": 250,
        "furnaceBias": 0.76
      }
    },
    "clearAnimation": {
      "enable": true,
      "timeoutMs": 500,
      "risePx": 28,
      "startOffsetYPx": 10,
      "textColor": "#ffe082",
      "textStrokeColor": "#4a2f05",
      "textStrokeThickness": 4,
      "textMinSizePx": 16,
      "textMaxSizePx": 40,
      "textSizeFactor": 0.62,
      "coin": {
        "enable": true,
        "showInPointsAnimation": true,
        "showInHud": true,
        "sizePx": 20,
        "gapPx": 6,
        "ridgeCount": 18
      }
    },
    "endFurnace": {
      "enable": true,
      "offsetX": 2
    },
    "preset": {
      "mode": "fixed",
      "id": "warehouse_concrete_checker"
    }
  },
  "conveyors": {
    "nConveyors": 4,
    "lengthPx": {
      "type": "uniform",
      "min": 860,
      "max": 1160
    },
    "speedPxPerSec": {
      "type": "fixed",
      "value": 30
    }
  },
  "bricks": {
    "completionMode": "hover_to_clear",
    "interaction": {
      "targetingArea": "conveyor"
    },
    "completionParams": {
      "target_hold_ms": 1000,
      "progress_per_perfect": 0.25,
      "progress_curve": 0.85,
      "overshoot_tolerance_ms": 180,
      "width_scaling": true,
      "width_reference_px": 80,
      "width_scaling_exponent": 1
    },
    "colorCategories": [
      {
        "id": "Target",
        "label": "High Value",
        "color": "#fbbf24",
        "value": {
          "type": "poisson",
          "lambda": 15,
          "min": 11,
          "max": 19
        }
      },
      {
        "id": "Other",
        "label": "Distractor",
        "color": {
          "type": "list",
          "values": [
            "#DDA0DD",
            "#66CDAA",
            "#d97706",
            "#FFB6C1",
            "#FF7F50",
            "#228B22",
            "#40E0D0"
          ],
          "without_replacement": true
        },
        "value": {
          "type": "poisson",
          "lambda": 5,
          "min": 1,
          "max": 9
        }
      }
    ],
    "initialBricks": {
      "type": "fixed",
      "value": 0
    },
    "forcedSet": [],
    "forcedSetPlan": {
      "enable": true,
      "count": 4,
      "defaults": {
        "width": {
          "type": "uniform",
          "min": 50,
          "max": 110
        }
      },
      "fields": {
        "conveyorIndex": {
          "values": [
            0,
            1,
            2,
            3
          ],
          "draw": "without_replacement"
        },
        "rightEdge": 150,
        "colorCategoryId": {
          "values": [
            "Target",
            "Other",
            "Other",
            "Other"
          ],
          "draw": "without_replacement"
        }
      }
    },
    "maxBricksPerTrial": 4,
    "spawn": {
      "ratePerSec": {
        "type": "fixed",
        "value": 0
      },
      "interSpawnDist": null,
      "minSpacingPx": 0,
      "byConveyor": true,
      "maxActivePerConveyor": 1
    }
  },
  "difficultyModel": {
    "holdQualityMean": 0.5
  },
  "trial": {
    "mode": "max_bricks",
    "maxTimeSec": null,
    "forcedOrder": {
      "enable": false
    }
  },
  "experiment": {
    "showBetweenBlockSummary": false,
    "startTrialsOn": "click",
    "startOverlay": {
      "text": "Click to begin.",
      "padding": "0",
      "background": "transparent",
      "border": "none",
      "borderRadius": "0",
      "boxShadow": "none",
      "buttonStyle": {
          "background": "black",
          "border": "none",
          "borderRadius": "999px",
          "padding": "18px 32px",
          "fontSize": "24px",
          "outline": "none",
          "boxShadow": "none"
       }
     },
    "statsPresentation": {
      "scopeByMetric": {
        "points": "experiment",
        "cleared": "trial",
        "dropped": "trial"
      },
      "reset": [
        {
          "at": "block_end",
          "scope": "experiment",
          "metrics": ["points"],
          "when": { "isPractice": true }
        }
      ]
    }
  },
  "surveys": {
    "postTrial": [
      {
        "preset": "atwit",
        "showQuestionNumbers": false,
        "showRequiredAsterisk": false,
        "questionBorder": "none",
        "questionBorderRadius": "0",
        "prompt": "Rate your overall workload during the just-completed trial (1-10).",
        "title": ""
      }
    ]
  },
  "blocks": [
    {
      "label": "Baseline",
      "trials": 4,
      "manipulation": "baseline"
    }
  ],
  "manipulations": [
    {
      "id": "baseline",
      "label": "VPT + VDD",
      "overrides": {}
    }
  ],
  "instructions": {
    "introPages": [
      {
        "title": "Task",
        "html": "<p>Four moving blocks represent four tasks. Block length indicates required processing time.</p><p>Each line ends at a vertical marker, which is that task's deadline.</p>"
      },
      {
        "title": "How To Process",
        "html": "<p>Press and hold on a block, then release. Aim for about {bricks.completionParams.target_hold_ms} ms holds to maximize progress.</p><p>Larger blocks require more successful holds than smaller blocks, reflecting their larger processing demand.</p>"
      },
      {
        "title": "Goal",
        "html": "<p>Complete as many tasks as possible before their deadlines. No partial credit is awarded when a block reaches its deadline line.</p><p>Click to begin each trial.</p>"
      }
    ]
  }
}
