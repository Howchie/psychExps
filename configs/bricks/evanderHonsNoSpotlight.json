{
  "task": {
    "implementation": "native_bricks",
    "runner": "native",
    "title": "Bricks Task",
    "modules": {
      "drt": {
        "enabled": true,
        "scope": "trial",
        "key": " ",
        "audio": {
          "volume": 0.0
        },
        "stimMode": "border",
        "border": {
            "widthPx": 10,
            "radiusPx": 0,
            "target": "display"
        },
        "isiSampler": {
          "type": "uniform",
          "min": 3000,
          "max": 5000
        },
        "transformPersistence": "session",
        "responseDeadlineMs": 2500,
        "parameterTransforms": [
          {
            "type": "wald_conjugate",
            "t0Mode": "min_rt_multiplier",
            "t0Multiplier": 0.5,
            "priorUpdate": {
              "enabled": true,
              "mode": "shift_means"
            }
          }
        ]
      }
    }
  },
  "display": {
    "canvasWidth": 800,
    "canvasHeight": 600,
    "viewportPaddingPx": 24,
    "backgroundColor": "#7f858a",
    "beltColor": "#e5e7eb",
    "beltHeight": 56,
    "beltGap": 50,
    "brickHeight": 36,
    "brickCornerRadius": 3,
    "beltTexture": {
        "scrollSnapMode": "screen",
        "scrollRenderMode": "auto"
    },
    "brickTextureOverlay": {
      "enable": true,
      "alpha": 1,
      "baseFillAlpha": 1,
      "plankCount": 3,
      "seamWidthPx": 1,
      "grainCount": 4,
      "nailRadiusPx": 1,
      "insetPx": 2,
      "styles": {
        "present_orange_purple": {
          "pattern": "gift_wrap",
          "baseFillColor": "#FFA500",
          "baseFillAlpha": 1,
          "alpha": 1,
          "ribbonColor": "#8c198c",
          "ribbonAlpha": 1,
          "ribbonWidthRatio": 0.2,
          "ribbonInsetPx": 2
        },
        "present_green_blue": {
          "pattern": "gift_wrap",
          "baseFillColor": "#149214",
          "baseFillAlpha": 1,
          "alpha": 1,
          "ribbonColor": "#15f4ee",
          "ribbonAlpha": 1,
          "ribbonWidthRatio": 0.2,
          "ribbonInsetPx": 2
        },
        "present_blue_silver": {
          "pattern": "gift_wrap",
          "baseFillColor": "#2563eb",
          "baseFillAlpha": 1,
          "alpha": 1,
          "ribbonColor": "#e2e8f0",
          "ribbonAlpha": 1,
          "ribbonWidthRatio": 0.2,
          "ribbonInsetPx": 2
        },
        "present_purple_gold": {
          "pattern": "gift_wrap",
          "baseFillColor": "#7c3aed",
          "baseFillAlpha": 1,
          "alpha": 1,
          "ribbonColor": "#ffc0cb",
          "ribbonAlpha": 1,
          "ribbonWidthRatio": 0.2,
          "ribbonInsetPx": 2
        },
        "crate_light_brown": {
          "pattern": "wood_planks",
          "baseFillColor": "#c79a6a",
          "baseFillAlpha": 1,
