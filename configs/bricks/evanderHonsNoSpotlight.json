            "tapeWidthRatio": 0.10,
            "tapeOrientation": "horizontal"
        },
        "box_med_brown": {
            "pattern": "cardboard_block",
            "baseFillColor": "#A7855E",
            "baseFillAlpha": 1,
            "alpha": 0.96,
            "plankCount": 0,
            "insetPx": 2,
            "speckleColor": "#7e5f40",
            "speckleAlpha": 0.16,
            "speckleCount": 25,
