        },
        "box_dark_brown": {
          "pattern": "cardboard_block",
          "baseFillColor": "#9A7651",
          "baseFillAlpha": 1,
          "alpha": 0.96,
          "plankCount": 0,
          "insetPx": 2,
          "speckleColor": "#7e5f40",
          "speckleAlpha": 0.16,
          "speckleCount": 25,
          "tapeColor": "#d9c2a2",
          "tapeAlpha": 0.5,
          "tapeWidthRatio": 0.1,
          "tapeOrientation": "horizontal"
        },
        "box_med_brown": {
          "pattern": "cardboard_block",
          "baseFillColor": "#A7855E",
          "baseFillAlpha": 1,
          "alpha": 0.96,
          "plankCount": 0,
          "insetPx": 2,
          "speckleColor": "#7e5f40",
          "speckleAlpha": 0.16,
          "speckleCount": 25,
          "tapeColor": "#d9c2a2",
          "tapeAlpha": 0.5,
          "tapeWidthRatio": 0.1,
          "tapeOrientation": "horizontal"
        }
      }
    },
    "ui": {
      "showHUD": true,
      "hudFontFamily": "\"Segoe UI\", \"Helvetica Neue\", Arial, sans-serif",
      "hudFontSize": 16,
      "hudFontWeight": 600,
      "hudPanel": true,
      "hudPanelColor": "#0f172a",
      "hudPanelAlpha": 0.38,
      "showTimer": false,
      "showRemainingBlocks": false,
      "showDroppedBlocks": true,
      "showPoints": true,
      "showDRT": false
    },
    "dueDateMarker": {
      "enable": true,
      "color": "#111827",
      "widthPx": 4,
      "heightPx": 44,
      "alpha": 0.95
    },
    "missAnimation": {
      "mode": "disintegrate",
      "durationMs": 240,
      "markerFlashMs": 150,
      "flashColor": "#ef4444",
      "disintegrate": {
        "shardCount": 30,
        "durationMs": 230,
        "gravityPxPerSec2": 620,
        "speedMinPxPerSec": 120,
        "speedMaxPxPerSec": 250,
        "furnaceBias": 0.15
      }
    },
    "clearAnimation": {
      "enable": true,
      "timeoutMs": 1000,
      "risePx": 28,
      "startOffsetYPx": 10,
      "textColor": "#ffe082",
      "textStrokeColor": "#4a2f05",
      "textStrokeThickness": 4,
      "textMinSizePx": 16,
      "textMaxSizePx": 40,
      "textSizeFactor": 0.62,
      "coin": {
        "enable": true,
        "showInPointsAnimation": true,
        "showInHud": true,
        "sizePx": 20,
        "gapPx": 6,
        "ridgeCount": 18
      }
    },
    "endFurnace": {
      "enable": true,
      "offsetX": 2
    },
    "preset": {
      "mode": "fixed",
      "id": "warehouse_concrete_checker"
    },
    "performance": {
      "maxDevicePixelRatio": 1.5,
      "antialias": true,
      "imageRendering": "auto",
      "pixelSnapBricks": true
    }
  },
  "conveyors": {
    "nConveyors": 4,
    "lengthPx": {
      "type": "uniform",
      "min": 560,
      "max": 740
    },
    "speedPxPerSec": {
      "type": "fixed",
      "value": 20
    }
  },
  "bricks": {
    "completionMode": "hold_to_clear",
    "interaction": {
      "targetingArea": "conveyor"
    },
    "completionParams": {
      "hold_process_rate_px_s": 12
    },
    "textureCategories": [
      {
        "id": "Target",
        "label": "High Value",
        "textureStyle": {
          "type": "list",
          "values": [
            "present_orange_purple",
            "present_green_blue",
            "present_blue_silver",
            "present_purple_gold"
          ]
        },
        "value": {
          "type": "poisson",
          "lambda": 1,
          "min": 5,
          "max": 8
        }
      },
      {
        "id": "Other",
        "label": "Distractor",
        "textureStyle": {
          "type": "list",
          "values": [
            "box_light_brown",
            "crate_light_brown",
            "box_med_brown",
            "crate_med_brown",
            "box_dark_brown",
            "crate_dark_brown"
          ],
          "without_replacement": true
        },
        "value": {
          "type": "poisson",
          "lambda": 1,
          "min": 1,
          "max": 4
        }
      }
    ],
    "initialBricks": {
      "type": "fixed",
      "value": 0
    },
    "forcedSet": [],
    "forcedSetPlan": {
      "enable": true,
      "count": 4,
      "defaults": {
        "width": {
          "type": "uniform",
          "min": 30,
          "max": 70
        }
      },
      "fields": {
        "conveyorIndex": {
          "values": [
            0,
            1,
            2,
            3
          ],
          "draw": "without_replacement"
        },
        "rightEdge": 150,
        "textureCategoryId": {
          "values": [
            "Other",
            "Other",
            "Other",
            "Other"
          ],
          "draw": "without_replacement"
        }
      }
    },
    "maxBricksPerTrial": 4,
    "spawn": {
      "ratePerSec": {
        "type": "fixed",
        "value": 0
      },
      "interSpawnDist": null,
      "minSpacingPx": 0,
      "byConveyor": true,
      "maxActivePerConveyor": 1
    }
  },
  "difficultyModel": {
    "holdQualityMean": 0.8
  },
  "trial": {
    "mode": "max_bricks",
    "maxTimeSec": null,
    "forcedOrder": {
      "enable": false,
      "switchMode": "on_clear",
      "switchOnDrop": true,
      "coverStory": {
        "enableAmmoCue": false
      }
    },
    "brickQuotaEndDelayMs": 1000,
    "stopDrtOnBrickQuotaMet": true
  },
  "experiment": {
    "showBetweenBlockSummary": true,
    "startTrialsOn": "click",
    "startOverlay": {
      "text": "Click to begin.",
      "padding": "0",
      "background": "transparent",
      "border": "none",
      "borderRadius": "0",
      "boxShadow": "none",
      "buttonStyle": {
        "background": "black",
        "border": "none",
        "borderRadius": "200px",
        "padding": "18px 32px",
        "fontSize": "24px",
        "outline": "none",
        "boxShadow": "none"
      }
    },
    "statsPresentation": {
      "scopeByMetric": {
        "points": "experiment",
        "cleared": "block",
        "dropped": "block"
      },
      "reset": [
        {
          "at": "block_end",
          "scope": "experiment",
          "metrics": [
            "points"
          ],
          "when": {
            "isPractice": true
          }
        }
      ]
    }
  },
  "surveys": {
    "postTrial": [
      {
        "preset": "atwit",
        "showQuestionNumbers": false,
        "showRequiredAsterisk": false,
        "questionBorder": "none",
        "questionBorderRadius": "0",
        "prompt": "Rate your overall workload during the just-completed trial (1-10).",
        "title": ""
      }
    ]
  },
  "manipulations": [
    {
      "id": "difficulty_practice",
      "label": "Practice speed",
      "overrides": {
        "conveyors": {
          "speedPxPerSec": {
            "type": "fixed",
            "value": 12
          }
        }
      }
    },
    {
      "id": "difficulty_low",
      "label": "Low speed",
      "overrides": {
        "conveyors": {
          "speedPxPerSec": {
            "type": "fixed",
            "value": 26
          }
        }
      }
    },
    {
      "id": "difficulty_high",
      "label": "High speed",
      "overrides": {
        "conveyors": {
          "speedPxPerSec": {
            "type": "fixed",
            "value": 32
          }
        }
      }
    },
    {
      "id": "condition_plan",
      "label": "Trial-wise target presence/order plan",
      "overrides": {},
      "trialPlan": {
        "schedule": {
          "mode": "quota_shuffle"
        },
        "variants": [
          {
            "id": "control",
            "label": "Control: no high-value brick",
            "overrides": {
              "bricks": {
                "forcedSetPlan": {
                  "fields": {
                    "textureCategoryId": {
                      "values": [
                        "Other",
                        "Other",
                        "Other",
                        "Other"
                      ],
                      "draw": "without_replacement"
                    }
                  }
                }
              }
            }
          },
          {
            "id": "target",
            "label": "High-value brick",
            "overrides": {
              "bricks": {
                "forcedSetPlan": {
                  "fields": {
                    "textureCategoryId": {
                      "values": [
                        "Target",
                        "Other",
                        "Other",
                        "Other"
                      ],
                      "draw": "without_replacement"
                    }
                  }
                }
              }
            }
          }
        ]
      }
    }
  ],
  "blocks": [
    {
      "label": "Practice1",
      "phase": "practice",
      "trials": 3,
      "overrides": {
        "task": {
          "modules": {
            "drt": {
              "enabled": false
            }
          }
        }
      },
      "repeatUntil": {
          "enabled": true,
          "maxAttempts": 3,
          "minMeanMetric": 3,
          "metrics": {
            "correctField": "game.stats.cleared",
            "metricField": "game.stats.cleared"
          }
      },
      "repeatAfterBlockScreens": [
        "Let's have another try.\nRemember: click and hold on the conveyor belt where a box is moving.\nKeep holding until the box opens, then release.\nDo this for each brick in turn."
      ],
      "manipulations": [
        "difficulty_practice",
        "condition_plan"
      ],
      "preBlockScreens": [
        "We will now try to open some boxes!\n\nIn the following trials, boxes will move slowly along the conveyor belts.\nYou must click and hold your mouse button on the conveyor belt to open each box.\n\nTry to open as many boxes as possible to collect more coins!\n\nAfter each trial you will be asked to rate your experienced workload on a scale of 1-10."
      ],
      "afterBlockScreens": [
        {
          "html": "<div style='font-family: system-ui, -apple-system, sans-serif; font-size: 1.2rem; line-height: 1.45;'>Well done!<p>As part of this experiment, you will also be asked to respond to a flashing stimulus called the DRT.<p>Whenever you see the border of the experiment window flash red, like this<p><img src='assets/drt_border.png' alt='DRT example' style='max-width: 480px; width: 100%; height: auto;'/><p>You should press the SPACEBAR as quickly as possible. This will happen repeatedly throughout the conveyor task.<p></div>"
        }
      ]
    },
    {
      "label": "DRTPractice",
      "phase": "practice",
      "trials": 1,
      "overrides": {
        "display": {
          "ui": {
            "showHUD": false
          }
        },
        "trial": {
          "mode": "fixed_time",
          "maxTimeSec": 60,
          "endDelayMs": 0,
          "forcedOrder": {
            "enable": false
          }
        },
        "bricks": {
          "initialBricks": {
            "type": "fixed",
            "value": 0
          },
          "forcedSet": [],
          "forcedSetPlan": {
            "enable": false,
            "count": 0
          },
          "maxBricksPerTrial": 0,
          "spawn": {
            "ratePerSec": {
              "type": "fixed",
              "value": 0
            },
            "initialBricks": 0,
            "interSpawnDist": null
          }
        },
        "surveys": {
          "postTrial": []
        }
      },
      "preBlockScreens": [
        "Let's practice the DRT.\nIgnore the conveyors and focus only on the red border signal.\n\nPress SPACEBAR as quickly as possible whenever the border flashes red.\n\nThis block will end after 60 seconds."
      ],
      "afterBlockScreens": ["Great job!\n\nWe will now do some practice trials putting both tasks together.\n\nRemember, use your mouse to open boxes by click-and-holding on the conveyor belt.\nPress SPACEBAR whenever you see the red square.\n\nThe conveyors will start to move a little more quickly now."]
    },
    {
      "label": "Practice2",
      "phase": "practice",
      "trials": 3,
      "manipulations": [
        "difficulty_low",
        "condition_plan"
      ],
      "afterBlockScreens": [
        "Great job! From here on you will always complete both the detection task and the conveyor task.\n\nThe conveyor will change speeds between blocks and sometimes it will be difficult to open all the boxes."
      ]
    },
    {
      "label": "Block1",
      "phase": "main",
      "trials": 4,
      "manipulations": [
        "difficulty_low",
        "condition_plan"
      ],
      "afterBlockScreens": [
        "The conveyors will move a little faster now."
      ]
    },
    {
      "label": "High Difficulty",
      "phase": "main",
      "trials": 4,
      "manipulations": [
        "difficulty_high",
        "condition_plan"
      ]
    }
  ],
  "instructions": {
    "introPages": [
      {
        "html": "<div style='font-family: system-ui, -apple-system, sans-serif; font-size: 1.2rem; line-height: 1.45;'>Welcome to the box task!<p>You will play a game where you will try to open as many boxes as you can within a time limit. Each trial will display four conveyor belts with moving boxes. Opening a box will give you a random reward in the form of coins.<p>Sometimes you will see a present - these are worth more coins.<p><img src='assets/brick_types.png' alt='Present vs Crate example' style='max-width: 480px; width: 100%; height: auto;'/><p>The width of a box or present indicates the required processing time.<p>Each line ends at a furnace. If any box or present reaches the furnace, it is destroyed and you will not get that reward.</div>"
      },
      "To open a box, click and hold the left mouse button anywhere on the conveyor belt while the box is under your cursor. Keep holding until the box disappears, then release and move to the next one. Wider boxes take longer to open."
    ],
    "blockSummary": {
      "enabled": true,
      "at": "block_end_before_post",
      "when": {
        "isPractice": false
      },
      "title": "End of {blockLabel}",
      "lines": [
        "Boxes opened: {blockCleared}",
        "Boxes lost: {blockDropped}",
        "Current coin balance: {experimentPoints}"
      ],
      "metrics": {
        "correctField": "responseCorrect",
        "rtField": "responseRtMs"
      }
    },
    "showBlockIntro": false,
    "showBlockLabel": false,
    "endPages": "That concludes the experiment.\nThank you very much for participating."
  }
}
