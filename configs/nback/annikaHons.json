{
  "task": {
    "title": "NBack PM Text",
    "rtTask": {
      "enabled": true,
      "timing": {
        "trialDurationMs": 3000,
        "fixationOnsetMs": 250,
        "fixationDurationMs": 500,
        "stimulusOnsetMs": 750,
        "stimulusDurationMs": 2250,
        "responseWindowStartMs": 750,
        "responseWindowEndMs": 3000
      },
      "responseTerminatesTrial": false
    },
    "modules": {
      "pm": {
        "enabled": "$var.pmEnabled",
        "eligibleTrialTypes": ["F"],
        "schedule": {
          "count": "$var.pmCount",
          "minSeparation": 8,
          "maxSeparation": 11
        },
        "rules": [
          {
            "type": "category_in",
            "categories": ["$var.pmCategories"],
            "responseKey": "space"
          }
        ]
      }
    }
  },
  "mapping": {
    "targetKey": "m",
    "nonTargetKey": "z"
  },
  "display": {
    "fixationFontSizePx": 24,
    "fixationFontWeight": 400,
    "stimulusFontSizePx": 30
  },
  "ui": {
    "pageBackground": "linear-gradient(180deg, #E8E8E8 0%, #DCDCDC 100%)"
  },
  "instructions": {
    "pages": [
      "Hi Annika, this is your experiment!",
      "In each trial, decide whether the item is an n-back match (M) or not (Z).\nThis is a test of line breaks :)"
    ],
    "blockIntroTemplate": "$var.blockIntro",
    "showBlockLabel": false,
    "preBlockBeforeBlockIntro": true
  },
  "stimuliCsv": {
    "basePath": "/assets/pm-words",
    "idColumn": "word",
    "categories": {
      "animals": "animals_members.csv",
      "animals_controls": "animals_controls.csv",
      "colours": "colours_members.csv",
      "colours_controls": "colours_controls.csv",
      "instruments": "instruments_members.csv",
      "instruments_controls": "instruments_controls.csv",
      "fruit/vegetables": "fruit_vegetables_members.csv",
      "fruit_vegetables_controls": "fruit_vegetables_controls.csv"
    }
  },
  "variables": {
    "pmEnabled": false,
    "pmCount": 0,
    "pmCategories": [],
    "blockIntro": "This is a {nLevel}-back block.",
    "between": {
      "scope": "participant",
      "sampler": {
        "type": "list",
        "values": [
          {
            "cell1Enabled": true,
            "cell1PmCount": 5,
            "cell1PmCategories": ["$pmCats.one"],
            "cell1Intro": "This is a {nLevel}-back PM block. Press SPACE for PM items from: animals.",
            "cell1PreScreen": "In the following blocks you will also perform a task we call \"PM\" (Prospective Memory).\nThe PM task requires you to press the spacebar on trials where a word belongs to a certain category.\nYou will be told what categories require a PM response before the block.\nIt is important that you remember to press the spacebar whenever you see a word belonging to those categories.",
            "cell1PostScreen": "",
            "cell2Enabled": true,
            "cell2PmCount": 5,
            "cell2PmCategories": ["$pmCats.three"],
            "cell2Intro": "This is a {nLevel}-back PM block. Press SPACE for PM items from: colours, instruments, fruit/vegetables.",
            "cell2PreScreen": "",
            "cell2PostScreen": "There will be no more PM trials from this point forward. Continue with standard n-back responses only.",
            "cell3Enabled": false,
            "cell3PmCount": 0,
            "cell3PmCategories": [],
            "cell3Intro": "This is a {nLevel}-back control block.",
            "cell3PreScreen": "",
            "cell3PostScreen": ""
          },
          {
            "cell1Enabled": true,
            "cell1PmCount": 5,
            "cell1PmCategories": ["$pmCats.three"],
            "cell1Intro": "This is a {nLevel}-back PM block. Press SPACE for items from: colours, instruments, fruit/vegetables.",
            "cell1PreScreen": "In the following blocks you will also perform the PM task.",
            "cell1PostScreen": "",
            "cell2Enabled": true,
            "cell2PmCount": 5,
            "cell2PmCategories": ["$pmCats.one"],
            "cell2Intro": "This is a {nLevel}-back PM block. Press SPACE for items from: animals.",
            "cell2PreScreen": "",
            "cell2PostScreen": "There will be no more PM trials from this point forward. Continue with standard n-back responses only.",
            "cell3Enabled": false,
            "cell3PmCount": 0,
            "cell3PmCategories": [],
            "cell3Intro": "This is a {nLevel}-back control block.",
            "cell3PreScreen": "",
            "cell3PostScreen": ""
          },
          {
            "cell1Enabled": false,
            "cell1PmCount": 0,
            "cell1PmCategories": [],
            "cell1Intro": "This is a {nLevel}-back control block.",
            "cell1PreScreen": "",
            "cell1PostScreen": "",
            "cell2Enabled": true,
            "cell2PmCount": 5,
            "cell2PmCategories": ["$pmCats.one"],
            "cell2Intro": "This is a {nLevel}-back PM block. Press SPACE for items from: animals.",
            "cell2PreScreen": "In the following blocks you will also perform the PM task.",
            "cell2PostScreen": "",
            "cell3Enabled": true,
            "cell3PmCount": 5,
            "cell3PmCategories": ["$pmCats.three"],
            "cell3Intro": "This is a {nLevel}-back PM block. Press SPACE for items from: colours, instruments, fruit/vegetables.",
            "cell3PreScreen": "",
            "cell3PostScreen": "There will be no more PM trials from this point forward. Continue with standard n-back responses only."
          },
          {
            "cell1Enabled": false,
            "cell1PmCount": 0,
            "cell1PmCategories": [],
            "cell1Intro": "This is a {nLevel}-back control block.",
            "cell1PreScreen": "",
            "cell1PostScreen": "",
            "cell2Enabled": true,
            "cell2PmCount": 5,
            "cell2PmCategories": ["$pmCats.three"],
            "cell2Intro": "This is a {nLevel}-back PM block. Press SPACE for items from: colours, instruments, fruit/vegetables.",
            "cell2PreScreen": "In the following blocks you will also perform the PM task.",
            "cell2PostScreen": "",
            "cell3Enabled": true,
            "cell3PmCount": 5,
            "cell3PmCategories": ["$pmCats.one"],
            "cell3Intro": "This is a {nLevel}-back PM block. Press SPACE for items from: animals.",
            "cell3PreScreen": "",
            "cell3PostScreen": "There will be no more PM trials from this point forward. Continue with standard n-back responses only."
          }
        ]
      }
    },
    "pmCats": {
      "one": ["animals"],
      "three": ["colours","instruments","fruit/vegetables"],
      "control": ["colours_controls","instruments_controls","fruit_vegetables_controls","animals_controls"]
    }
  },
  "nbackRule": {
    "lureLagPasses": [ [2, 4, 5], [6, 7, 8, 9] ],
    "maxInsertionAttempts": 10
  },
  "plan": {
    "manipulations": [
      {
        "id": "cell_1",
        "overrides": {
          "nLevel": 2,
          "variables": {
            "pmEnabled": "$between.cell1Enabled",
            "pmCount": "$between.cell1PmCount",
            "pmCategories": "$between.cell1PmCategories",
            "blockIntro": "$between.cell1Intro"
          },
          "beforeBlockScreens": ["$between.cell1PreScreen"],
          "afterBlockScreens": ["$between.cell1PostScreen"],
          "nbackSourceCategories": ["$pmCats.control"]
        }
      },
      {
        "id": "cell_2",
        "overrides": {
          "nLevel": 2,
          "variables": {
            "pmEnabled": "$between.cell2Enabled",
            "pmCount": "$between.cell2PmCount",
            "pmCategories": "$between.cell2PmCategories",
            "blockIntro": "$between.cell2Intro"
          },
          "beforeBlockScreens": ["$between.cell2PreScreen"],
          "afterBlockScreens": ["$between.cell2PostScreen"],
          "nbackSourceCategories": ["$pmCats.control"]
        }
      },
      {
        "id": "cell_3",
        "overrides": {
          "nLevel": 2,
          "variables": {
            "pmEnabled": "$between.cell3Enabled",
            "pmCount": "$between.cell3PmCount",
            "pmCategories": "$between.cell3PmCategories",
            "blockIntro": "$between.cell3Intro"
          },
          "beforeBlockScreens": ["$between.cell3PreScreen"],
          "afterBlockScreens": ["$between.cell3PostScreen"],
          "nbackSourceCategories": ["$pmCats.control"]
        }
      }
    ],
    "blocks": [
      { "phase": "main", "label": "Block 1", "manipulation": "cell_1", "trials": 54 },
      { "phase": "main", "label": "Block 2", "manipulation": "cell_2", "trials": 54 },
      { "phase": "main", "label": "Block 3", "manipulation": "cell_3", "trials": 54 }
    ]
  },
  "feedback": {
    "enabled": false
  }
}
