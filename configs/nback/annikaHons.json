{
  "task": {
    "title": "NBack PM Text",
    "rtTask": {
      "enabled": true,
      "timing": {
        "trialDurationMs": 3000,
        "fixationOnsetMs": 250,
        "fixationDurationMs": 500,
        "stimulusOnsetMs": 750,
        "stimulusDurationMs": 2250,
        "responseWindowStartMs": 750,
        "responseWindowEndMs": 3000
      },
      "responseTerminatesTrial": false
    }
  },
  "mapping": {
    "targetKey": "m",
    "nonTargetKey": "z",
    "pmKey": "space"
  },
  "display": {
    "fixationFontSizePx": 24,
    "fixationFontWeight": 400,
    "stimulusFontSizePx": 30
  },
  "ui": {
    "pageBackground": "linear-gradient(180deg, #E8E8E8 0%, #DCDCDC 100%)"
  },
  "instructions": {
    "pages": [
      "Hi Annika, this is your experiment!",
      "In each trial, decide whether the item is an n-back match (M) or not (Z).\nThis is a test of line breaks :)"
    ],
    "pmTemplate": "",
    "showBlockLabel": false,
    "preBlockBeforeBlockIntro": true,
    "blockIntroControlTemplate": "This is a {nLevel}-back control block.",
    "blockIntroPmTemplate": "This is a {nLevel}-back PM block. Press SPACE for PM items from: {pmCategoryText}."
  },
  "stimuliCsv": {
    "basePath": "assets/pm-words",
    "idColumn": "word",
    "categories": {
      "animals": "animals_members.csv",
      "animals_controls": "animals_controls.csv",
      "colours": "colours_members.csv",
      "colours_controls": "colours_controls.csv",
      "instruments": "instruments_members.csv",
      "instruments_controls": "instruments_controls.csv",
      "fruit/vegetables": "fruit_vegetables_members.csv",
      "fruit_vegetables_controls": "fruit_vegetables_controls.csv"
    }
  },
  "variables": {
    "between": {
      "scope": "participant",
      "sampler": {
        "type": "list",
        "values": [
          {
            "cell1Type": "pm",
            "cell1PmCategories": [
              "$pmCats.one"
            ],
            "cell1PreScreen": "In the following blocks you will also perform a task we call \"PM\" (Prospective Memory).\nThe PM task requires you to press the spacebar on trials where a word belongs to a certain category.\nYou will be told what categories require a PM response before the block.\nIt is important that you remember to press the spacebar whenever you see a word belonging to those categories.",
            "cell1PostScreen": "",
            "cell2Type": "pm",
            "cell2PmCategories": [
              "$pmCats.three"
            ],
            "cell2PreScreen": "",
            "cell2PostScreen": "There will be no more PM trials from this point forward. Continue with standard n-back responses only.",
            "cell3Type": "control",
            "cell3PreScreen": "",
            "cell3PostScreen": "",
            "cell3PmCategories": []
          },
          {
            "cell1Type": "pm",
            "cell1PmCategories": [
              "$pmCats.three"
            ],
            "cell1PreScreen": "In the following blocks you will also perform the PM task.",
            "cell1PostScreen": "",
            "cell2Type": "pm",
            "cell2PmCategories": [
              "$pmCats.one"
            ],
            "cell2PreScreen": "",
            "cell2PostScreen": "There will be no more PM trials from this point forward. Continue with standard n-back responses only.",
            "cell3Type": "control",
            "cell3PreScreen": "",
            "cell3PostScreen": "",
            "cell3PmCategories": []
          },
          {
            "cell1Type": "control",
            "cell1PreScreen": "",
            "cell1PostScreen": "",
            "cell1PmCategories": [],
            "cell2Type": "pm",
            "cell2PmCategories": [
              "$pmCats.one"
            ],
            "cell2PreScreen": "In the following blocks you will also perform the PM task.",
            "cell2PostScreen": "",
            "cell3Type": "pm",
            "cell3PmCategories": [
              "$pmCats.three"
            ],
            "cell3PreScreen": "",
            "cell3PostScreen": "There will be no more PM trials from this point forward. Continue with standard n-back responses only."
          },
          {
            "cell1Type": "control",
            "cell1PreScreen": "",
            "cell1PostScreen": "",
            "cell1PmCategories": [],
            "cell2Type": "pm",
            "cell2PmCategories": [
              "$pmCats.three"
            ],
            "cell2PreScreen": "In the following blocks you will also perform the PM task.",
            "cell2PostScreen": "",
            "cell3Type": "pm",
            "cell3PmCategories": [
              "$pmCats.one"
            ],
            "cell3PreScreen": "",
            "cell3PostScreen": "There will be no more PM trials from this point forward. Continue with standard n-back responses only."
          }
        ]
      }
    },
    "pmCats": {
      "one": ["animals"],
      "three": ["colours","instruments","fruit/vegetables"],
      "control": ["colours_controls","instruments_controls","fruit_vegetables_controls","animals_controls"]
    }
  },
  "nbackRule": {
    "lureLagPasses": [ [2, 4, 5], [6, 7, 8, 9] ],
    "maxInsertionAttempts": 10
  },
  "plan": {
    "manipulations": [
      {
        "id": "cell_1",
        "overrides": {
          "blockType": "$between.cell1Type",
          "nLevel": 2,
          "activePmCategories": [
            "$between.cell1PmCategories"
          ],
          "beforeBlockScreens": [
            "$between.cell1PreScreen"
          ],
          "afterBlockScreens": [
            "$between.cell1PostScreen"
          ],
         "controlSourceCategories": [],
         "nbackSourceCategories": ["$pmCats.control"]
        }
      },
      {
        "id": "cell_2",
        "overrides": {
          "blockType": "$between.cell2Type",
          "nLevel": 2,
          "activePmCategories": [
            "$between.cell2PmCategories"
          ],
          "beforeBlockScreens": [
            "$between.cell2PreScreen"
          ],
          "afterBlockScreens": [
            "$between.cell2PostScreen"
          ],
         "controlSourceCategories": [],
         "nbackSourceCategories": ["$pmCats.control"]
        }
      },
      {
        "id": "cell_3",
        "overrides": {
          "blockType": "$between.cell3Type",
          "nLevel": 2,
          "activePmCategories": [
            "$between.cell3PmCategories"
          ],
          "beforeBlockScreens": [
            "$between.cell3PreScreen"
          ],
          "afterBlockScreens": [
            "$between.cell3PostScreen"
          ],
         "controlSourceCategories": [],
         "nbackSourceCategories": ["$pmCats.control"]
        }
      }
    ],
    "blocks": [
      {
        "phase": "main",
        "label": "Block 1",
        "manipulation": "cell_1",
        "trials": 54
      },
      {
        "phase": "main",
        "label": "Block 2",
        "manipulation": "cell_2",
        "trials": 54
      },
      {
        "phase": "main",
        "label": "Block 3",
        "manipulation": "cell_3",
        "trials": 54
      }
    ]
  },
  "feedback": {
    "enabled": false,
    "style": {
      "canvasBackground": "#ffffff",
      "canvasBorder": "2px solid #ddd",
      "correctColor": "#16a34a",
      "incorrectColor": "#dc2626",
      "timeoutColor": "#d97706",
      "invalidColor": "#d97706"
    }
  }
}
