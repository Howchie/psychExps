{
  "task": {
    "implementation": "jspsych_nback",
    "runner": "jspsych",
    "title": "NBack + PM Module Demo",
    "rtTask": {
      "enabled": true,
      "timing": {
        "trialDurationMs": 5000,
        "fixationOnsetMs": 0,
        "fixationDurationMs": 500,
        "stimulusOnsetMs": 1000,
        "stimulusDurationMs": 4000,
        "responseWindowStartMs": 1000,
        "responseWindowEndMs": 5000
      },
      "responseTerminatesTrial": false
    },
    "modules": {
      "injector": {
        "enabled": true,
        "injections": [
          {
            "id": "pm_injection",
            "enabled": true,
            "eligibleTrialTypes": ["F"],
            "schedule": {
              "count": "$var.pmCount",
              "minSeparation": 8,
              "maxSeparation": 11
            },
            "source": {
              "type": "category_in",
              "categories": ["$var.pmCategory"]
            },
            "sourceDraw": {
              "mode": "without_replacement",
              "scope": "block",
              "shuffle": true
            },
            "set": {
              "trialType": "PM",
              "itemCategory": "PM",
              "correctResponse": "space",
              "responseCategory": "pm"
            }
          }
        ]
      }
    }
  },
  "mapping": {
    "targetKey": "m",
    "nonTargetKey": "z"
  },
  "variables": {
    "pmCount": 0,
    "pmCategory": "animals",
    "pmCategories": ["animals", "fruits"],
    "blockIntro": "This is a {nLevel}-back block."
  },
  "instructions": {
    "introPages": [
      "Respond M for n-back targets and Z for non-targets.",
      "In PM blocks, press SPACE for PM-category items."
    ],
    "blockIntroTemplate": "$var.blockIntro",
    "preBlockBeforeBlockIntro": false,
    "showBlockLabel": true
  },
  "nbackRule": {
    "lureLagPasses": [[2, 4, 5], [6, 7, 8, 9]],
    "maxInsertionAttempts": 10
  },
  "stimulusPools": {
    "nbackDraw": {
      "mode": "without_replacement",
      "shuffle": true
    }
  },
  "stimuli": {
    "animals": ["cat", "dog", "horse", "mouse", "otter", "goat", "crow", "koala", "moose", "shark"],
    "fruits": ["apple", "pear", "grape", "melon", "mango", "kiwi", "plum", "lime", "papaya", "peach"],
    "tools": ["hammer", "saw", "drill", "pliers", "wrench", "chisel", "anvil", "lathe", "vise", "ruler"],
    "other": ["amber", "brook", "cedar", "dune", "ember", "fjord", "gale", "haven", "islet", "jetty", "knoll", "lagoon", "mesa", "nimbus", "oasis", "prairie", "quartz", "ridge", "shore", "tundra", "upland", "valley", "willow", "xylem", "yarrow", "zephyr"]
  },
  "plan": {
    "manipulations": [
      { "id": "control_block", "overrides": { "variables": { "pmCount": 0, "blockIntro": "This is a {nLevel}-back control block. No PM responses in this block." } } },
      { "id": "pm_block_animals", "overrides": { "variables": { "pmCount": 5, "pmCategory": "animals", "blockIntro": "This is a {nLevel}-back PM block. Watch for: animals." } } },
      { "id": "pm_block_fruits", "overrides": { "variables": { "pmCount": 5, "pmCategory": "fruits", "blockIntro": "This is a {nLevel}-back PM block. Watch for: fruits." } } },
      { "id": "nlevel_1", "overrides": { "nLevel": 1 } },
      { "id": "nlevel_2", "overrides": { "nLevel": 2 } },
      { "id": "nlevel_3", "overrides": { "nLevel": 3 } }
    ],
    "blocks": [
      { "phase": "practice", "label": "Practice 2-back Control", "manipulations": ["control_block", "nlevel_2"], "trials": 20 },
      { "phase": "practice", "label": "Practice 1-back PM", "manipulations": ["pm_block_animals", "nlevel_1"], "trials": 20 },
      { "phase": "practice", "label": "Practice 3-back Control", "manipulations": ["control_block", "nlevel_3"], "trials": 20 },
      { "phase": "main", "label": "Main 1", "manipulations": ["pm_block_animals", "nlevel_1"], "trials": 54 },
      { "phase": "main", "label": "Main 2", "manipulations": ["control_block", "nlevel_2"], "trials": 54 },
      { "phase": "main", "label": "Main 3", "manipulations": ["pm_block_fruits", "nlevel_3"], "trials": 54 },
      { "phase": "main", "label": "Main 4", "manipulations": ["control_block", "nlevel_1"], "trials": 54 }
    ]
  }
}
