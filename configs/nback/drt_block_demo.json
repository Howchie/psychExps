{
  "task": {
    "implementation": "jspsych_nback",
    "runner": "jspsych",
    "title": "NBack DRT Block Demo",
    "rtTask": {
      "enabled": true,
      "timing": {
        "trialDurationMs": 2500,
        "fixationOnsetMs": 0,
        "fixationDurationMs": 300,
        "stimulusOnsetMs": 700,
        "stimulusDurationMs": 1600,
        "responseWindowStartMs": 700,
        "responseWindowEndMs": 2300
      },
      "responseTerminatesTrial": false
    },
    "drt": {
      "enabled": true,
      "scope": "block",
      "key": "space",
      "transformPersistence": "session",
      "responseWindowMs": 2500,
      "displayDurationMs": 1000,
      "responseTerminatesStimulus": true,
      "parameterTransforms": [
        {
          "type": "wald_conjugate",
          "id": "drt_wald_online",
          "includeOutcomes": ["hit"],
          "minWindowSize": 10,
          "maxWindowSize": 50,
          "t0": 180,
          "priors": {
            "mu0": 2,
            "precision0": 1,
            "kappa0": 6,
            "beta0": 1
          },
          "credibleInterval": {
            "lower": 0.05,
            "upper": 0.95
          },
          "priorUpdate": {
            "enabled": true,
            "mode": "shift_means"
          }
        }
      ],
      "stimMode": "visual",
      "visual": {
        "shape": "square",
        "color": "#dc2626",
        "sizePx": 34,
        "topPx": 16
      },
      "isiSampler": {
        "type": "uniform",
        "min": 3000,
        "max": 5000
      }
    }
  },
  "mapping": {
    "targetKey": "/",
    "nonTargetKey": "none"
  },
  "instructions": {
    "intro": "Press / for n-back targets only. For non-targets, withhold response. While the block runs, respond to DRT probes with spacebar.",
    "blockIntroTemplate": "This is a {nLevel}-back block with concurrent DRT across the full block."
  },
  "nbackRule": {
    "lureLagPasses": [],
    "maxInsertionAttempts": 12
  },
  "stimulusPools": {
    "nbackDraw": {
      "mode": "without_replacement",
      "shuffle": true
    }
  },
  "stimuli": {
    "other": [
      "1",
      "2",
