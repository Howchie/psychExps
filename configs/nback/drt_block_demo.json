      "5",
      "6",
      "7",
      "8",
      "9",
      "1",
      "2",
      "3",
      "4",
      "5",
      "6",
      "7",
      "8",
      "9"
    ]
  },
  "plan": {
    "blocks": [
      {
        "phase": "main",
        "label": "Main 2-back DRT (Visual)",
        "nLevel": 2,
        "trials": 27,
        "targetCount": 6,
        "lureCount": 0,
        "nbackSourceCategories": ["other"],
        "beforeBlockScreens": [
          "Primary task: press / only when the current number matches the one 2-back.",
          "Secondary task (DRT): whenever a probe appears, press space as quickly as possible."
        ]
      },
      {
        "phase": "main",
        "label": "Main 2-back DRT (Border)",
        "nLevel": 2,
        "trials": 27,
        "targetCount": 6,
        "lureCount": 0,
        "nbackSourceCategories": ["other"],
        "drt": {
          "stimMode": "border",
          "border": {
            "color": "#dc2626",
            "widthPx": 4,
            "radiusPx": 0,
            "target": "display"
          }
        },
        "beforeBlockScreens": [
          "This block uses border-flash DRT probes on the experiment display boundary.",
          "Keep using / for targets and space for DRT probes."
        ]
      }
    ]
  },
  "display": {
