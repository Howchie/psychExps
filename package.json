{
  "name": "experiments-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tasks/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev -w @experiments/web",
    "eeg:bridge": "node scripts/eeg-bridge.mjs",
    "eeg:session": "node scripts/run-eeg-session.mjs",
    "test:auto": "playwright test -c playwright.config.ts",
    "autoresponder:url": "node scripts/run-autoresponder-url.mjs"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
